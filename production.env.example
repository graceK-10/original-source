# Production Environment Configuration Example
# Copy this file to .env for your production environment

# Server Configuration
PORT=4040

# JWT Configuration
JWT_SECRET=your-secure-jwt-secret-key-should-be-long-and-random
JWT_EXPIRES_IN=30m

# Refresh Tokens
REFRESH_JWT_SECRET=your-secure-refresh-secret-key-should-be-different
REFRESH_JWT_EXPIRES_IN=7d

# Production Cookie Settings
# For cross-domain setup (API on different domain than frontend)
COOKIE_SAMESITE=none
# For subdomain support (e.g. api.yourdomain.com and app.yourdomain.com)
COOKIE_DOMAIN=.yourdomain.com
# Required for cross-domain cookies with SameSite=None
HTTPS=true

# Set NODE_ENV to production
NODE_ENV=production

# CORS Configuration
# Comma-separated list of allowed origins
CLIENT_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# InstaPay Configuration
INSTAPAY_MERCHANT_UUID=your-merchant-uuid
INSTAPAY_ACCOUNT_UUID=your-account-uuid
INSTAPAY_SITE_ID=your-site-id
INSTAPAY_SECURITY_KEY=your-security-key
INSTAPAY_MEMBER_ID=your-member-id
INSTAPAY_IACCOUNT_ID=your-iaccount-id

# Production URLs
INSTAPAY_MAIN_URL=https://yourdomain.com
INSTAPAY_SUCCESS_URL=https://yourdomain.com/payment-success
INSTAPAY_NOTIFICATION_URL=https://yourdomain.com/api/payment/notifications
INSTAPAY_SHOP_URL=https://yourdomain.com/products
INSTAPAY_FAILURE_URL=https://yourdomain.com/payment-failed

# Email Configuration
SMTP_HOST=your-smtp-host
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
FROM_EMAIL=your-from-email
TO_EMAIL=your-to-email
ADMIN_ORDER_EMAIL=admin-order-email

# Contact form email settings
CONTACT_SMTP_USER=contact-form-user
CONTACT_SMTP_PASS=contact-form-password
CONTACT_SMTP_HOST=contact-smtp-host
CONTACT_SMTP_PORT=465
CONTACT_TO=contact-recipient-email
